# PostgreSQL connection string used by Prisma and backend runtime.
# Replace user, password, host, port, and db name for your local setup.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ros_db?schema=public"

# JWT signing secret for staff auth tokens and table HMAC verification.
# Use a strong random value in real environments.
JWT_SECRET="replace_with_a_strong_secret"
